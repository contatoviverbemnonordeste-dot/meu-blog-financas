---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Artigos | Viver Bem no Nordeste" description="Leia nossos últimos artigos sobre investimentos.">
  <div class="py-8">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8 border-b-2 border-emerald-100 pb-4">Nossos Artigos</h1>
    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="flex flex-col bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-xl hover:border-emerald-300 transition-all overflow-hidden group">
          <div class="h-48 bg-gray-100 w-full overflow-hidden relative border-b border-gray-200">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            ) : (
              <div class="absolute inset-0 bg-emerald-50 flex items-center justify-center text-emerald-200 group-hover:scale-110 transition-transform duration-500">
                <span class="text-5xl">📸</span>
              </div>
            )}
          </div>
          <div class="p-6 flex-grow flex flex-col">
            <span class="text-xs font-bold text-amber-500 uppercase mb-2 tracking-wider">Novo Guia</span>
            <h2 class="text-xl font-extrabold text-gray-900 mb-3 leading-tight group-hover:text-emerald-700 transition-colors">{post.data.title}</h2>
            <p class="text-gray-600 text-sm mb-4 flex-grow line-clamp-3">{post.data.description}</p>
            <span class="text-sm font-bold text-emerald-600 mt-auto">Ler artigo completo &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
